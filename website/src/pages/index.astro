import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="GAIA — Private AI on your Ryzen AI PC">
  <!-- Neural Network / Circuit Background -->
  <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
    <div class="circuit-bg"></div>
    <div class="neural-network"></div>
    <div class="data-stream stream-1"></div>
    <div class="data-stream stream-2"></div>
    <div class="processor-glow glow-1"></div>
    <div class="processor-glow glow-2"></div>
  </div>

  <Header />
  <main id="main-content">

    <!-- ============================================================== -->
    <!-- 1. HERO — Agent UI focus                                        -->
    <!-- ============================================================== -->
    <section class="min-h-[80vh] flex items-center px-4 sm:px-6 lg:px-8 pt-24 pb-16">
      <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Left: pitch + download CTAs -->
        <div class="overflow-visible">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-8">
            Your AI agent.<br />
            <span class="text-gaia-accent whitespace-nowrap">100% on your PC.</span>
          </h1>

          <p class="text-xl text-gaia-muted mb-10 max-w-lg leading-relaxed">
            GAIA is the open-source desktop app and SDK for running AI agents locally on AMD Ryzen AI hardware. Chat with your documents in the app today; build voice, code, and image agents with the SDK — without sending a single token to the cloud.
          </p>

          <!-- Download CTAs -->
          <div class="mb-6 space-y-3">
            <p class="text-xs text-gaia-muted uppercase tracking-wider">Download the Agent UI</p>

            <!-- Primary OS-detected button -->
            <a
              id="download-primary"
              href="https://github.com/amd/gaia/releases/latest"
              class="download-primary inline-flex w-full max-w-md items-center justify-between gap-4 px-5 py-4 bg-gaia-accent hover:bg-gaia-accent/90 text-white font-semibold rounded-lg transition-all shadow-lg shadow-gaia-accent/20 hover:shadow-gaia-accent/40"
            >
              <span class="flex items-center gap-3">
                <svg id="download-os-icon" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <!-- Default: download icon, replaced by OS icon via JS -->
                  <path d="M12 16l-5-5h3V4h4v7h3l-5 5zm-7 4v-2h14v2H5z"/>
                </svg>
                <span id="download-label">Download for your platform</span>
              </span>
              <span id="download-version" class="text-xs font-mono opacity-80">latest</span>
            </a>

            <!-- Secondary OS buttons -->
            <div class="flex flex-wrap gap-2 text-sm">
              <a id="dl-windows" href="https://github.com/amd/gaia/releases/latest" class="os-pill" data-os="windows">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5.479L10.5 4.5v7.5H3V5.479zm0 13.042V12h7.5v7.5L3 18.521zM11.5 12H21v7.5l-9.5-1V12zm0-7.5L21 3.5V11h-9.5V4.5z"/></svg>
                Windows
              </a>
              <a id="dl-macos" href="https://github.com/amd/gaia/releases/latest" class="os-pill" data-os="macos">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
                macOS
              </a>
              <a id="dl-linux-deb" href="https://github.com/amd/gaia/releases/latest" class="os-pill" data-os="linux-deb">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.99.99 0 00-.111.165c-.265.39-.482.602-.738.804-.262.198-.51.273-.804.341-.293.08-.617.16-.946.426l-.018.014a1.51 1.51 0 00-.503 1.213c.013.255.092.482.234.65.142.169.347.305.585.357.165.04.336.04.485 0 .07-.018.143-.045.226-.082.098-.041.225-.09.382-.143.317-.105.748-.214 1.21-.207.215.004.435.024.661.07.09.018.18.041.27.069.058.018.116.038.173.06.121.046.243.097.367.155.066.029.131.06.197.094.094.046.187.094.281.146a.86.86 0 00.119.057.825.825 0 00.243.052c.087.005.176-.007.262-.04.085-.034.165-.084.236-.146.142-.122.259-.279.366-.444.214-.331.392-.687.535-1.058.292-.72.519-1.502.668-2.318.077-.405.13-.812.18-1.219.05-.408.087-.819.115-1.231.013-.205.024-.412.034-.618.005-.103.01-.206.014-.309.005-.103.009-.205.013-.308.008-.205.013-.41.013-.616 0-.412-.014-.823-.04-1.232-.027-.41-.066-.819-.114-1.224-.097-.81-.245-1.611-.439-2.39-.388-1.555-1-3.026-1.838-4.302-.42-.638-.875-1.243-1.398-1.766-.522-.523-1.103-.962-1.74-1.27-.318-.155-.65-.272-.99-.341-.34-.07-.69-.082-1.038-.054z"/></svg>
                Linux .deb
              </a>
              <a id="dl-linux-appimage" href="https://github.com/amd/gaia/releases/latest" class="os-pill" data-os="linux-appimage">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                Linux AppImage
              </a>
            </div>

            <p class="text-xs text-gaia-muted">
              Or browse all builds and checksums on
              <a href="https://github.com/amd/gaia/releases/latest" class="text-gaia-accent hover:underline">GitHub Releases →</a>
            </p>
          </div>

          <!-- What's in the app today -->
          <div class="mt-7 pt-6 border-t border-gaia-border/40">
            <p class="text-xs text-gaia-muted uppercase tracking-wider mb-3">In the app today</p>
            <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
              <a href="https://amd-gaia.ai/docs/guides/chat" class="text-gaia-muted hover:text-white transition-colors">Chat Agent (RAG)</a>
              <a href="https://amd-gaia.ai/docs/guides/agent-ui" class="text-gaia-muted hover:text-white transition-colors">File browser</a>
              <a href="https://amd-gaia.ai/docs/integrations/mcp" class="text-gaia-muted hover:text-white transition-colors">MCP integrations</a>
              <a href="https://amd-gaia.ai/docs/playbooks/custom-installer" class="text-gaia-muted hover:text-white transition-colors">Custom agents</a>
            </div>
          </div>
        </div>

        <!-- Right: Agent UI demo zone (drop your screenshot/video here) -->
        <div>
          <div class="demo-zone bg-gaia-card rounded-xl border border-gaia-border overflow-hidden relative aspect-[16/10]">
            <!-- ============================================================ -->
            <!-- DEMO ASSET DROP ZONE                                          -->
            <!--                                                                -->
            <!-- Replace this <div class="demo-placeholder"> with one of:       -->
            <!--                                                                -->
            <!-- 1. Screenshot:                                                 -->
            <!--    <img src="/agent-ui.png" alt="GAIA Agent UI"                -->
            <!--         class="w-full h-full object-cover" />                  -->
            <!--                                                                -->
            <!-- 2. Looping video (autoplay muted):                             -->
            <!--    <video autoplay muted loop playsinline                      -->
            <!--           poster="/agent-ui-poster.png"                        -->
            <!--           class="w-full h-full object-cover">                  -->
            <!--      <source src="/agent-ui-demo.mp4" type="video/mp4" />      -->
            <!--    </video>                                                    -->
            <!--                                                                -->
            <!-- 3. Animated GIF:                                               -->
            <!--    <img src="/agent-ui-demo.gif" alt="GAIA Agent UI"           -->
            <!--         class="w-full h-full object-cover" />                  -->
            <!--                                                                -->
            <!-- Drop the asset into website/public/ — Astro serves /public/    -->
            <!-- at the root, so /agent-ui.png maps to public/agent-ui.png.     -->
            <!-- ============================================================ -->
            <div class="demo-placeholder absolute inset-0 flex flex-col">
              <!-- Mock window chrome -->
              <div class="flex items-center gap-2 px-4 py-3 bg-gaia-bg/60 border-b border-gaia-border">
                <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
                <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
                <span class="ml-3 text-xs text-gaia-muted font-mono">GAIA Agent UI</span>
              </div>
              <!-- Mock chat surface -->
              <div class="flex-1 flex flex-col gap-3 p-6 overflow-hidden">
                <div class="self-start max-w-[75%] px-4 py-2 rounded-2xl rounded-tl-sm bg-gaia-bg/80 text-sm text-gaia-text border border-gaia-border">
                  Summarise my Q4 sales report from <span class="text-gaia-accent">~/Reports</span>.
                </div>
                <div class="self-end max-w-[80%] px-4 py-2 rounded-2xl rounded-tr-sm bg-gaia-accent/15 text-sm text-gaia-text border border-gaia-accent/30">
                  <span class="block mb-1">Found <strong>q4-sales.pdf</strong> · 47 pages · indexed locally</span>
                  Q4 revenue rose <strong>18% YoY</strong> to $4.2M, led by enterprise renewals (+34%). Net new logos slowed (-9%). Margin compressed 2pts on cloud spend.
                </div>
                <div class="self-start text-xs text-gaia-muted font-mono pl-2">
                  <span class="inline-block w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                  Running locally on Ryzen AI NPU
                </div>
              </div>
            </div>
          </div>
          <p class="text-xs text-gaia-muted text-center mt-3 font-mono opacity-60">
            (placeholder — drop screenshot/video into website/public/)
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================================== -->
    <!-- 2. Capability strip                                              -->
    <!-- ============================================================== -->
    <section class="px-4 sm:px-6 lg:px-8 py-20 border-t border-gaia-border/50">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-3xl lg:text-4xl font-bold text-white mb-3">Everything an AI assistant can do —<br /><span class="text-gaia-accent">without the cloud bill.</span></h2>
          <p class="text-gaia-muted max-w-2xl mx-auto">Some capabilities ship inside the desktop app today; the rest live in the GAIA Python SDK while the app catches up.</p>
          <div class="flex justify-center gap-4 mt-5 text-xs">
            <span class="inline-flex items-center gap-1.5"><span class="badge badge-today">Today</span><span class="text-gaia-muted">In the Agent UI app</span></span>
            <span class="inline-flex items-center gap-1.5"><span class="badge badge-sdk">SDK</span><span class="text-gaia-muted">Python / CLI only — Agent UI integration coming</span></span>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="capability-card">
            <div class="flex items-start justify-between gap-2 mb-1">
              <h3 class="font-semibold text-white">Chat with your documents</h3>
              <span class="badge badge-today flex-shrink-0">Today</span>
            </div>
            <p class="text-sm text-gaia-muted">Drop a PDF in, ask questions. RAG runs locally — your files never leave the machine.</p>
          </div>
          <div class="capability-card">
            <div class="flex items-start justify-between gap-2 mb-1">
              <h3 class="font-semibold text-white">Connect your stack</h3>
              <span class="badge badge-today flex-shrink-0">Today</span>
            </div>
            <p class="text-sm text-gaia-muted">MCP client + bridge means Jira, Docker, GitHub, Slack — anything with an MCP server.</p>
          </div>
          <div class="capability-card">
            <div class="flex items-start justify-between gap-2 mb-1">
              <h3 class="font-semibold text-white">Talk to it out loud</h3>
              <span class="badge badge-sdk flex-shrink-0">SDK</span>
            </div>
            <p class="text-sm text-gaia-muted">Whisper ASR + Kokoro TTS for voice in, voice out. Run via <code class="text-gaia-accent text-xs">gaia talk</code>.</p>
          </div>
          <div class="capability-card">
            <div class="flex items-start justify-between gap-2 mb-1">
              <h3 class="font-semibold text-white">Generate code</h3>
              <span class="badge badge-sdk flex-shrink-0">SDK</span>
            </div>
            <p class="text-sm text-gaia-muted">A code agent that orchestrates tools, validates output, and writes files. Run via <code class="text-gaia-accent text-xs">gaia-code</code>.</p>
          </div>
          <div class="capability-card">
            <div class="flex items-start justify-between gap-2 mb-1">
              <h3 class="font-semibold text-white">Generate images</h3>
              <span class="badge badge-sdk flex-shrink-0">SDK</span>
            </div>
            <p class="text-sm text-gaia-muted">Stable Diffusion XL Turbo on the iGPU. Prompt → PNG in seconds, fully offline.</p>
          </div>
          <div class="capability-card">
            <div class="flex items-start justify-between gap-2 mb-1">
              <h3 class="font-semibold text-white">Automate Blender</h3>
              <span class="badge badge-sdk flex-shrink-0">SDK</span>
            </div>
            <p class="text-sm text-gaia-muted">Drive 3D scene creation by chat — the agent talks to Blender over MCP.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================== -->
    <!-- 3. Why local                                                     -->
    <!-- ============================================================== -->
    <section class="px-4 sm:px-6 lg:px-8 py-20">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-xs text-gaia-accent uppercase tracking-wider mb-3 font-semibold">Why local</p>
            <h2 class="text-3xl lg:text-4xl font-bold text-white mb-5">Stop renting AI.<br />Start owning it.</h2>
            <ul class="space-y-3 text-gaia-muted">
              <li class="flex gap-3"><span class="text-gaia-accent flex-shrink-0">→</span><span><strong class="text-white">No API keys.</strong> No spend. No rate limits.</span></li>
              <li class="flex gap-3"><span class="text-gaia-accent flex-shrink-0">→</span><span><strong class="text-white">No data leaves your PC.</strong> HIPAA-friendly by construction — there is nowhere for it to go.</span></li>
              <li class="flex gap-3"><span class="text-gaia-accent flex-shrink-0">→</span><span><strong class="text-white">NPU + iGPU acceleration.</strong> Optimised for AMD Ryzen AI via Lemonade Server.</span></li>
              <li class="flex gap-3"><span class="text-gaia-accent flex-shrink-0">→</span><span><strong class="text-white">Open source, MIT licensed.</strong> Fork it, ship it inside your product, run it on a plane.</span></li>
            </ul>
          </div>

          <div class="bg-gaia-card border border-gaia-border rounded-xl p-6">
            <p class="text-xs text-gaia-muted uppercase tracking-wider mb-5">Architecture</p>
            <div class="space-y-2">
              <div class="arch-step"><span class="arch-label">You</span><span class="arch-meta">human</span></div>
              <div class="arch-arrow">↓</div>
              <div class="arch-step"><span class="arch-label">Agent UI</span><span class="arch-meta">desktop app</span></div>
              <div class="arch-arrow">↓</div>
              <div class="arch-step"><span class="arch-label">GAIA SDK</span><span class="arch-meta">Python / C++</span></div>
              <div class="arch-arrow">↓</div>
              <div class="arch-step"><span class="arch-label">Lemonade Server</span><span class="arch-meta">local LLM runtime</span></div>
              <div class="arch-arrow">↓</div>
              <div class="arch-step arch-step-final"><span class="arch-label">Ryzen AI NPU + iGPU</span><span class="arch-meta">your silicon</span></div>
            </div>
            <p class="text-gaia-muted text-xs text-center mt-5 pt-4 border-t border-gaia-border/50">Network calls in this stack: <strong class="text-white">zero</strong></p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================== -->
    <!-- 4. For developers — SDK install + code typewriter                -->
    <!-- ============================================================== -->
    <section class="px-4 sm:px-6 lg:px-8 py-20 border-t border-gaia-border/50">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <p class="text-xs text-gaia-accent uppercase tracking-wider mb-3 font-semibold">For developers</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-white mb-3">Build your own agent in a few lines.</h2>
          <p class="text-gaia-muted max-w-2xl mx-auto">Same SDK that powers the Agent UI — Pythonic, composable, with built-in chat, RAG, MCP, voice, and vision.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <!-- SDK install -->
          <div>
            <p class="text-xs text-gaia-muted uppercase tracking-wider mb-3">Install the SDK</p>

            <!-- Install method tabs -->
            <div class="flex gap-1 flex-wrap">
              <button class="os-tab active" data-os="uv">uv (fastest)</button>
              <button class="os-tab" data-os="pip">pip</button>
              <button class="os-tab" data-os="windows">Windows script</button>
              <button class="os-tab" data-os="linux">Linux script</button>
            </div>

            <div class="bg-gaia-card rounded-xl rounded-tl-none border border-gaia-border overflow-hidden">
              <div class="p-4">
                <div id="install-uv" class="install-cmd flex items-center justify-between gap-4">
                  <code class="font-mono text-sm text-gaia-text flex-1">uv pip install amd-gaia</code>
                  <button class="copy-install-btn flex-shrink-0 p-2 bg-transparent hover:bg-gaia-muted/10 rounded text-gaia-muted hover:text-white transition-all" data-copy="uv pip install amd-gaia" title="Copy">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                  </button>
                </div>
                <div id="install-pip" class="install-cmd hidden flex items-center justify-between gap-4">
                  <code class="font-mono text-sm text-gaia-text flex-1">pip install amd-gaia</code>
                  <button class="copy-install-btn flex-shrink-0 p-2 bg-transparent hover:bg-gaia-muted/10 rounded text-gaia-muted hover:text-white transition-all" data-copy="pip install amd-gaia" title="Copy">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                  </button>
                </div>
                <div id="install-windows" class="install-cmd hidden flex items-center justify-between gap-4">
                  <code class="font-mono text-sm text-gaia-text flex-1">irm https://amd-gaia.ai/install.ps1 | iex</code>
                  <button class="copy-install-btn flex-shrink-0 p-2 bg-transparent hover:bg-gaia-muted/10 rounded text-gaia-muted hover:text-white transition-all" data-copy="irm https://amd-gaia.ai/install.ps1 | iex" title="Copy">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                  </button>
                </div>
                <div id="install-linux" class="install-cmd hidden flex items-center justify-between gap-4">
                  <code class="font-mono text-sm text-gaia-text flex-1">curl -fsSL https://amd-gaia.ai/install.sh | sh</code>
                  <button class="copy-install-btn flex-shrink-0 p-2 bg-transparent hover:bg-gaia-muted/10 rounded text-gaia-muted hover:text-white transition-all" data-copy="curl -fsSL https://amd-gaia.ai/install.sh | sh" title="Copy">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                  </button>
                </div>
              </div>
            </div>

            <p class="text-xs text-gaia-muted mt-4">
              <strong class="text-gaia-text">uv / pip</strong> install the Python package only.
              The <strong class="text-gaia-text">Windows / Linux</strong> scripts also set up Lemonade Server and download default models.
              C++ developers — see the <a href="https://amd-gaia.ai/docs/cpp/setup" class="text-gaia-accent hover:underline">C++ setup guide</a>.
            </p>

            <div class="mt-6 flex flex-wrap gap-3 text-sm">
              <a href="https://amd-gaia.ai/docs/quickstart" class="px-4 py-2 bg-gaia-card border border-gaia-border rounded-lg text-gaia-text hover:border-gaia-accent transition-colors">Quickstart</a>
              <a href="https://amd-gaia.ai/docs/sdk" class="px-4 py-2 bg-gaia-card border border-gaia-border rounded-lg text-gaia-text hover:border-gaia-accent transition-colors">SDK reference</a>
              <a href="https://github.com/amd/gaia" class="px-4 py-2 bg-gaia-card border border-gaia-border rounded-lg text-gaia-text hover:border-gaia-accent transition-colors">GitHub</a>
            </div>
          </div>

          <!-- Code typewriter -->
          <div>
            <div class="flex gap-1 px-4 pt-4 flex-wrap">
              <button class="folder-tab active" data-tab="docs" data-file="rag_doc_agent.py">Document Q&amp;A</button>
              <button class="folder-tab" data-tab="voice" data-file="voice_agent.py">Voice</button>
              <button class="folder-tab" data-tab="code" data-file="code_agent.py">Code Gen</button>
              <button class="folder-tab" data-tab="workflow" data-file="file_watcher_agent.py">Automation</button>
              <button class="folder-tab" data-tab="mcp" data-file="weather_agent.py">MCP</button>
            </div>

            <div class="bg-gaia-card rounded-xl rounded-tl-none border border-gaia-border overflow-hidden relative">
              <pre class="p-8 overflow-x-auto h-[420px] flex items-start"><code id="code-display" class="font-mono text-sm text-gaia-text leading-relaxed"><span class="cursor-code">|</span></code></pre>
              <button id="copy-code-btn" class="absolute bottom-4 right-4 p-2 bg-transparent hover:bg-gaia-muted/10 rounded text-gaia-muted hover:text-white transition-all" title="Copy code">
