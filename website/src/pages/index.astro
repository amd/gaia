<script is:inline>
  // ===== Detect OS and pick the right primary download =====
  function detectOS() {
    const ua = navigator.userAgent;
    if (/Win/i.test(ua)) return 'windows';
    if (/Mac/i.test(ua)) return 'macos';
    if (/Linux/i.test(ua)) return 'linux';
    return 'unknown';
  }

  const osIcons = {
    windows: '<path d="M3 5.479L10.5 4.5v7.5H3V5.479zm0 13.042V12h7.5v7.5L3 18.521zM11.5 12H21v7.5l-9.5-1V12zm0-7.5L21 3.5V11h-9.5V4.5z"/>',
    macos: '<path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>',
    linux: '<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>'
  };

  const osLabels = {
    windows: 'Download for Windows',
    macos: 'Download for macOS',
    linux: 'Download for Linux',
    unknown: 'Download GAIA'
  };

  // ===== Fetch latest release and wire up direct-download URLs =====
  async function fetchLatestRelease() {
    const primaryBtn = document.getElementById('download-primary');
    const primaryLabel = document.getElementById('download-label');
    const primaryIcon = document.getElementById('download-os-icon');
    const versionBadge = document.getElementById('download-version');
    const detectedOS = detectOS();

    // Update icon and label based on detected OS, even before fetch resolves
    if (osIcons[detectedOS]) primaryIcon.innerHTML = osIcons[detectedOS];
    primaryLabel.textContent = osLabels[detectedOS];

    // Mark the matching pill button as detected
    const pillMap = { windows: 'dl-windows', macos: 'dl-macos', linux: 'dl-linux-deb' };
    const pillId = pillMap[detectedOS];
    if (pillId) document.getElementById(pillId)?.classList.add('detected');

    try {
      const res = await fetch('https://api.github.com/repos/amd/gaia/releases/latest', {
        headers: { Accept: 'application/vnd.github+json' }
      });
      if (!res.ok) throw new Error('GitHub API ' + res.status);
      const data = await res.json();
      const tag = data.tag_name || '';
      const assets = data.assets || [];

      // Match assets by suffix
      const findAsset = (suffix) => assets.find(a => a.name.endsWith(suffix));
      const winExe = findAsset('-x64-setup.exe');
      const macDmgArm = findAsset('-arm64.dmg');
      const macDmgIntel = findAsset('-x64.dmg') || findAsset('-x86_64.dmg');
      const linuxDeb = findAsset('-amd64.deb');
      const linuxApp = findAsset('-x86_64.AppImage');

      // Update each pill with its direct download URL
      if (winExe) document.getElementById('dl-windows').href = winExe.browser_download_url;
      const macAsset = macDmgArm || macDmgIntel;
      if (macAsset) document.getElementById('dl-macos').href = macAsset.browser_download_url;
      if (linuxDeb) document.getElementById('dl-linux-deb').href = linuxDeb.browser_download_url;
      if (linuxApp) document.getElementById('dl-linux-appimage').href = linuxApp.browser_download_url;

      // Update primary button to point at detected OS asset
      const primaryAsset = {
        windows: winExe,
        macos: macAsset,
        linux: linuxDeb || linuxApp
      }[detectedOS];

      if (primaryAsset) {
        primaryBtn.href = primaryAsset.browser_download_url;
      }

      // Mirror the same logic on the final CTA at the bottom of the page.
      const finalBtn = document.getElementById('download-final');
      const finalLabel = document.getElementById('download-final-label');
      const finalVersion = document.getElementById('download-final-version');
      if (finalBtn && primaryAsset) {
        finalBtn.href = primaryAsset.browser_download_url;
      }
      if (finalLabel && osLabels[detectedOS]) {
        finalLabel.textContent = osLabels[detectedOS];
      }
      if (finalVersion && tag) {
        finalVersion.textContent = tag;
      }

      if (tag) versionBadge.textContent = tag;
    } catch (err) {
      // Graceful fallback: leave links pointing at /releases/latest
      console.warn('Could not fetch latest release, falling back to releases page', err);
      versionBadge.textContent = 'latest';
    }
  }

  fetchLatestRelease();

  // ===== SDK install: OS tab switching =====
  const osTabs = document.querySelectorAll('.os-tab');
  const installCmds = document.querySelectorAll('.install-cmd');

  osTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const targetOS = tab.getAttribute('data-os');
      osTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      installCmds.forEach(cmd => {
        if (cmd.id === `install-${targetOS}`) {
          cmd.classList.remove('hidden');
        } else {
          cmd.classList.add('hidden');
        }
      });
    });
  });

  // ===== Copy buttons for install commands =====
  document.querySelectorAll('.copy-install-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy') || '';
      await navigator.clipboard.writeText(text);
      const originalIcon = btn.innerHTML;
      btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>`;
      btn.classList.add('text-green-400');
      setTimeout(() => {
        btn.innerHTML = originalIcon;
        btn.classList.remove('text-green-400');
      }, 2000);
    });
  });

  // ===== Code typewriter for SDK section =====
  const codeExamples = {
    docs: `<span class="text-purple-400">from</span> <span class="text-yellow-400">gaia.rag.sdk</span> <span class="text-purple-400">import</span> RAGSDK, RAGConfig

