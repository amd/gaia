import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AgentIcon from '../../components/AgentIcon.astro';
import { renderMarkdown } from '../../data/markdown';
import {
  getCatalog,
  categoryLabel,
  languageLabel,
  securityTierLabel,
  securityTierClasses,
  formatBytes,
  platformLabel,
  type Agent,
} from '../../data/catalog';

export async function getStaticPaths() {
  const agents = await getCatalog();
  return agents.map((agent) => ({
    params: { id: agent.id },
    props: { agent },
  }));
}

interface Props {
  agent: Agent;
}

const { agent } = Astro.props;
const installCmd = `gaia agent install ${agent.id}`;
const deepLink = `gaia://hub/install/${agent.id}`;
const readmeHtml = renderMarkdown(agent.readme);

const req = agent.requirements;
const requirementRows: Array<[string, string]> = [
  ['Memory', `${req.min_memory_gb} GB min`],
  ['Disk', `${req.min_disk_gb} GB min`],
  ['Context size', `${req.min_context_size.toLocaleString()} tokens`],
  ['NPU', req.npu === 'optional' ? 'Optional' : req.npu],
  ['GPU VRAM', req.gpu_vram_gb > 0 ? `${req.gpu_vram_gb} GB` : 'Not required'],
];
---

<Layout
  title={`${agent.name} — Agent Hub — gaia`}
  description={agent.description}
>
  <Header />
  <main id="main-content" class="pt-16">
    <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm text-gaia-muted" aria-label="Breadcrumb">
        <a href="/hub" class="transition-colors hover:text-white">Agent Hub</a>
        <span class="mx-2 text-gaia-border">/</span>
        <span class="text-gaia-text">{agent.name}</span>
      </nav>

      <!-- Header block -->
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex items-start gap-4">
          <span class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-xl bg-gaia-accent/10 text-gaia-accent">
            <AgentIcon name={agent.icon} class="w-7 h-7" />
          </span>
          <div>
            <div class="flex flex-wrap items-center gap-3">
              <h1 class="text-2xl font-bold text-white sm:text-3xl">{agent.name}</h1>
              <span
                class={`rounded-md border px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wide ${securityTierClasses(agent.security_tier)}`}
              >
                {securityTierLabel(agent.security_tier)}
              </span>
              {agent.deprecated && (
                <span class="rounded-md border border-gaia-border bg-gaia-bg/60 px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wide text-gaia-muted">
                  Deprecated
                </span>
              )}
            </div>
            <p class="mt-2 max-w-2xl text-gaia-muted">{agent.description}</p>
            <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gaia-muted">
              <span class="font-mono">v{agent.latest_version}</span>
              <span class="text-gaia-border">·</span>
              <span>{categoryLabel(agent.category)}</span>
              <span class="text-gaia-border">·</span>
              <span>{languageLabel(agent.language)}</span>
              <span class="text-gaia-border">·</span>
              <span>{formatBytes(agent.download_size_bytes)}</span>
              <span class="text-gaia-border">·</span>
              <span>by {agent.author}</span>
            </div>
          </div>
        </div>
      </div>

      {agent.deprecated && agent.deprecation_message && (
        <div class="mt-6 rounded-lg border border-yellow-500/30 bg-yellow-500/10 px-4 py-3 text-sm text-yellow-200">
          <strong class="font-semibold">This agent is deprecated.</strong> {agent.deprecation_message}
        </div>
      )}

      <!-- Install actions -->
      <div class="mt-8 rounded-xl border border-gaia-border bg-gaia-card/60 p-5">
        <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-gaia-muted">Install</p>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <div class="flex flex-1 items-center justify-between gap-3 rounded-lg border border-gaia-border bg-gaia-bg px-4 py-3">
            <code class="font-mono text-sm text-gaia-text">{installCmd}</code>
            <button
              id="copy-install"
              class="flex-shrink-0 rounded p-1.5 text-gaia-muted transition-colors hover:bg-gaia-muted/10 hover:text-white"
              data-copy={installCmd}
              title="Copy install command"
              aria-label="Copy install command"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
              </svg>
            </button>
          </div>
          <a
            href={deepLink}
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-gaia-accent px-5 py-3 text-sm font-semibold text-white transition-all hover:bg-gaia-accent/90"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
            Open in GAIA
          </a>
        </div>
        <p class="mt-3 text-xs text-gaia-muted">
          "Open in GAIA" launches the desktop app with this agent pre-selected. Don't have it yet?
          <a href="/" class="text-gaia-accent hover:underline">Download gaia →</a>
        </p>
      </div>

      <!-- Body grid: README + sidebar -->
      <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-[1fr_280px]">
        <!-- README -->
        <article class="min-w-0">
          <h2 class="sr-only">About {agent.name}</h2>
          <div class="readme" set:html={readmeHtml} />
        </article>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <div class="rounded-xl border border-gaia-border bg-gaia-card/60 p-5">
            <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-gaia-muted">System requirements</h3>
            <dl class="space-y-2 text-sm">
              {requirementRows.map(([label, value]) => (
                <div class="flex items-center justify-between gap-3">
                  <dt class="text-gaia-muted">{label}</dt>
                  <dd class="text-right text-gaia-text">{value}</dd>
                </div>
              ))}
            </dl>
            <div class="mt-4 border-t border-gaia-border/60 pt-4">
              <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-gaia-muted">Platforms</p>
              <div class="flex flex-wrap gap-1.5">
                {req.platforms.map((p) => (
                  <span class="rounded-md border border-gaia-border bg-gaia-bg/60 px-2 py-0.5 text-xs text-gaia-text">
                    {platformLabel(p)}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <div class="rounded-xl border border-gaia-border bg-gaia-card/60 p-5">
            <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-gaia-muted">Details</h3>
            <dl class="space-y-2 text-sm">
              <div class="flex items-center justify-between gap-3">
                <dt class="text-gaia-muted">Version</dt>
                <dd class="font-mono text-gaia-text">{agent.latest_version}</dd>
              </div>
              <div class="flex items-center justify-between gap-3">
                <dt class="text-gaia-muted">Min gaia</dt>
                <dd class="font-mono text-gaia-text">{agent.min_gaia_version}</dd>
              </div>
              <div class="flex items-center justify-between gap-3">
                <dt class="text-gaia-muted">Tools</dt>
                <dd class="text-gaia-text">{agent.tools_count}</dd>
              </div>
              <div class="flex items-center justify-between gap-3">
                <dt class="text-gaia-muted">License</dt>
                <dd class="text-gaia-text">MIT</dd>
              </div>
            </dl>
            <div class="mt-4 border-t border-gaia-border/60 pt-4">
              <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-gaia-muted">Models</p>
              <div class="flex flex-wrap gap-1.5">
                {agent.models.map((m) => (
                  <span class="rounded-md border border-gaia-border bg-gaia-bg/60 px-2 py-0.5 font-mono text-xs text-gaia-text">{m}</span>
                ))}
              </div>
            </div>
            <div class="mt-4 border-t border-gaia-border/60 pt-4">
              <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-gaia-muted">Permissions</p>
              <div class="flex flex-wrap gap-1.5">
                {agent.permissions.map((p) => (
                  <span class="rounded-md border border-gaia-border bg-gaia-bg/60 px-2 py-0.5 font-mono text-xs text-gaia-text">{p}</span>
                ))}
              </div>
            </div>
            {agent.tags.length > 0 && (
              <div class="mt-4 border-t border-gaia-border/60 pt-4">
                <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-gaia-muted">Tags</p>
                <div class="flex flex-wrap gap-1.5">
                  {agent.tags.map((t) => (
                    <a href={`/hub?q=${encodeURIComponent(t)}`} class="rounded-md border border-gaia-border bg-gaia-bg/60 px-2 py-0.5 text-xs text-gaia-muted transition-colors hover:border-gaia-accent/40 hover:text-white">
                      {t}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>

          <a
            href="/hub"
            class="inline-flex items-center gap-1.5 text-sm text-gaia-muted transition-colors hover:text-white"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M19 12H5M12 19l-7-7 7-7" />
            </svg>
            Back to all agents
          </a>
        </aside>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline>
  const copyBtn = document.getElementById('copy-install');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const text = copyBtn.getAttribute('data-copy') || '';
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        return;
      }
      const original = copyBtn.innerHTML;
      copyBtn.innerHTML =
        '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
      copyBtn.classList.add('text-green-400');
      setTimeout(() => {
        copyBtn.innerHTML = original;
        copyBtn.classList.remove('text-green-400');
      }, 2000);
    });
  }
</script>
