import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import AgentIcon from '../../components/AgentIcon.astro';
import InstallMethods from '../../components/InstallMethods.astro';
import TerminalBlock from '../../components/TerminalBlock.astro';
import {
  getCatalog,
  getAgent,
  categoryLabel,
  languageLabel,
  securityTierLabel,
  securityTierDescription,
  formatBytes,
  platformLabel,
  npuLabel,
} from '../../data/catalog';
import { renderMarkdown } from '../../data/markdown';

export async function getStaticPaths() {
  const agents = await getCatalog();
  return agents.map((a) => ({ params: { id: a.id } }));
}

const { id } = Astro.params;
const agent = (await getAgent(id!))!;

// npm-distributed agents (the email sidecar) install via npm, not the GAIA app /
// pip. Surface only the path that actually works — see installMethods().
const isNpm = !!agent.npm_package;
const npmUrl = agent.npm_package ? `https://www.npmjs.com/package/${agent.npm_package}` : '';
const installCmd = isNpm ? `npm i ${agent.npm_package}` : `gaia agent install ${agent.id}`;
const deepLink = `gaia://hub/install/${agent.id}`;
const readmeHtml = renderMarkdown(agent.readme);
// Optional — older index.json (served before the hub Worker adds the field) has
// no changelog; render the section only when there's content.
const changelogHtml = agent.changelog ? renderMarkdown(agent.changelog) : '';
const req = agent.requirements;
const terminalLines = [
  { prompt: true, text: installCmd },
  { muted: true, text: `✓ ${agent.name} ${agent.latest_version} installed` },
  // Non-npm agents launch via the CLI; the npm client is embedded by the host app.
  ...(isNpm ? [] : [{ prompt: true, text: `gaia ${agent.id}` }]),
];
---

<Layout title={`${agent.name} — Agent Hub — gaia`} description={agent.description}>
  <Header />
  <main id="main-content" class="max-w-5xl mx-auto px-6 pt-32 pb-28">

    <a href="/hub" class="text-sm text-g-muted hover:text-g-text transition-colors">← Agent Hub</a>

    <!-- Header -->
    <header class="mt-8 flex flex-col sm:flex-row sm:items-start gap-6">
      <span class="flex-none w-16 h-16 rounded-xl border border-g-border bg-g-surface flex items-center justify-center text-g-gold-text">
        <AgentIcon name={agent.icon} class="w-8 h-8" />
      </span>
      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="text-3xl font-bold tracking-tight">{agent.name}</h1>
          <span class="text-[10px] font-bold tracking-wide uppercase text-g-gold-text border border-g-gold/40 rounded px-2 py-0.5">
            {securityTierLabel(agent.security_tier)}
          </span>
        </div>
        <p class="mt-2 text-g-muted max-w-2xl">{agent.description}</p>
        {agent.deprecated && (
          <p class="mt-3 text-sm text-g-muted border border-g-border rounded-md px-3 py-2">
            Deprecated{agent.deprecation_message ? ` — ${agent.deprecation_message}` : ''}
          </p>
        )}
        {!isNpm && (
          <div class="mt-6 flex flex-wrap items-center gap-3">
            <a href={deepLink} class="rounded-md bg-g-gold px-6 py-3 text-sm font-semibold text-black hover:brightness-110 transition">
              Open in GAIA
            </a>
          </div>
        )}
        <p class="mt-4 text-xs text-g-muted">
          {isNpm ? (
            // The playground needs install + a running sidecar, so its launcher lives
            // in the README's Playground section, not as a hero button.
            <span>Install with npm below, then drive it from your app. <a href={npmUrl} class="text-g-gold-text hover:underline">View on npm →</a></span>
          ) : (
            <span>Don't have GAIA yet? <a href="https://amd-gaia.ai/docs" class="text-g-gold-text hover:underline">Get started →</a></span>
          )}
        </p>
      </div>
    </header>

    <!-- Install chrome: switcher + platform badges, both manifest-driven -->
    <section class="mt-12" aria-label="Install">
      <Eyebrow class="mb-3">Install</Eyebrow>
      <div class="max-w-xl">
        <InstallMethods agent={agent} />
      </div>
      <div class="mt-4 flex flex-wrap items-center gap-1.5">
        <span class="text-[11px] text-g-muted mr-1">Runs on:</span>
        {req.platforms.map((p) => (
          <span class="text-[11px] text-g-muted border border-g-border rounded px-2 py-0.5">{platformLabel(p)}</span>
        ))}
      </div>
    </section>

    <!-- Body: tabbed docs (README / Changelog) + manifest-driven cards -->
    <div class="mt-12 grid lg:grid-cols-[minmax(0,1fr)_280px] gap-12">
      <div class="min-w-0" data-doc-tabs>
        {changelogHtml && (
          <div role="tablist" aria-label={`${agent.name} documentation`} class="flex gap-1 border-b border-g-border mb-7">
            <button type="button" role="tab" id="doctab-readme" aria-controls="docpanel-readme" data-doc-tab="readme" aria-selected="true" tabindex="0" class="doc-tab">README</button>
            <button type="button" role="tab" id="doctab-changelog" aria-controls="docpanel-changelog" data-doc-tab="changelog" aria-selected="false" tabindex="-1" class="doc-tab">Changelog</button>
          </div>
        )}
        <article role="tabpanel" id="docpanel-readme" aria-labelledby="doctab-readme" data-doc-panel="readme" class="doc max-w-[70ch]">
          <h2 class="sr-only">About {agent.name}</h2>
          <div set:html={readmeHtml} />
          <div class="mt-10">
            <TerminalBlock lines={terminalLines} typing />
          </div>
        </article>
        {changelogHtml && (
          <article role="tabpanel" id="docpanel-changelog" aria-labelledby="doctab-changelog" data-doc-panel="changelog" class="doc max-w-[70ch]" hidden>
            <div set:html={changelogHtml} />
          </article>
        )}
      </div>

      <aside class="space-y-5">
        <!-- Security tier card -->
        <section class="rounded-xl border border-g-border bg-g-surface p-5">
          <div class="flex items-center justify-between gap-2">
            <Eyebrow>Security tier</Eyebrow>
            <span class="text-[10px] font-bold tracking-wide uppercase text-g-gold-text border border-g-gold/40 rounded px-2 py-0.5">
              {securityTierLabel(agent.security_tier)}
            </span>
          </div>
          <p class="mt-2 text-[12.5px] leading-relaxed text-g-muted">{securityTierDescription(agent.security_tier)}</p>
        </section>

        <!-- Details card -->
        <section class="rounded-xl border border-g-border bg-g-surface p-5">
          <Eyebrow class="mb-2">Details</Eyebrow>
          <dl class="text-[13px]">
            <div class="flex justify-between py-2 border-b border-g-border">
              <dt class="text-g-muted">Version</dt><dd class="font-mono">{agent.latest_version}</dd>
            </div>
            {agent.download_size_bytes > 0 && (
              <div class="flex justify-between py-2 border-b border-g-border">
                <dt class="text-g-muted">Size</dt><dd class="font-mono">{formatBytes(agent.download_size_bytes)}</dd>
              </div>
            )}
            <div class="flex justify-between py-2 border-b border-g-border">
              <dt class="text-g-muted">Author</dt><dd>{agent.author}</dd>
            </div>
            <div class="flex justify-between py-2 border-b border-g-border">
              <dt class="text-g-muted">Language</dt><dd>{languageLabel(agent.language)}</dd>
            </div>
            <div class="flex justify-between py-2 border-b border-g-border">
              <dt class="text-g-muted">Category</dt><dd>{categoryLabel(agent.category)}</dd>
            </div>
            <div class="flex justify-between py-2 last:border-0 border-b border-g-border">
              <dt class="text-g-muted">Min GAIA</dt><dd class="font-mono">{agent.min_gaia_version || '—'}</dd>
            </div>
          </dl>
        </section>

        <!-- Requirements card -->
        <section class="rounded-xl border border-g-border bg-g-surface p-5">
          <Eyebrow class="mb-2">Requirements</Eyebrow>
          <dl class="text-[13px]">
            {req.min_memory_gb > 0 && (
              <div class="flex justify-between py-2 border-b border-g-border">
                <dt class="text-g-muted">Memory</dt><dd class="font-mono">{req.min_memory_gb} GB</dd>
              </div>
            )}
            {req.min_disk_gb > 0 && (
              <div class="flex justify-between py-2 border-b border-g-border">
                <dt class="text-g-muted">Disk</dt><dd class="font-mono">{req.min_disk_gb} GB</dd>
              </div>
            )}
            {req.min_context_size > 0 && (
              <div class="flex justify-between py-2 border-b border-g-border">
                <dt class="text-g-muted">Context</dt><dd class="font-mono">{req.min_context_size.toLocaleString()}</dd>
              </div>
            )}
            <div class="flex justify-between py-2 border-b border-g-border">
              <dt class="text-g-muted">NPU</dt><dd>{npuLabel(req.npu)}</dd>
            </div>
            {req.gpu_vram_gb > 0 && (
              <div class="flex justify-between py-2 border-b border-g-border">
                <dt class="text-g-muted">GPU VRAM</dt><dd class="font-mono">{req.gpu_vram_gb} GB</dd>
              </div>
            )}
          </dl>
        </section>

        {agent.models.length > 0 && (
          <section class="rounded-xl border border-g-border bg-g-surface p-5">
            <Eyebrow class="mb-2">Models</Eyebrow>
            <ul class="text-[12px] font-mono text-g-muted space-y-1.5">
              {agent.models.map((m) => <li>{m}</li>)}
            </ul>
          </section>
        )}

        {agent.permissions.length > 0 && (
          <section class="rounded-xl border border-g-border bg-g-surface p-5">
            <Eyebrow class="mb-2">Permissions</Eyebrow>
            <ul class="flex flex-wrap gap-1.5">
              {agent.permissions.map((p) => (
                <li class="text-[11px] font-mono text-g-muted border border-g-border rounded px-2 py-0.5">{p}</li>
              ))}
            </ul>
          </section>
        )}
      </aside>
    </div>

  </main>
  <Footer />

  <!-- Fullscreen image lightbox for rendered README/CHANGELOG diagrams. -->
  <div
    id="doc-lightbox"
    class="fixed inset-0 z-[100] hidden cursor-zoom-out items-center justify-center bg-black/90 p-6 backdrop-blur-sm"
    aria-hidden="true"
    role="dialog"
    aria-label="Image preview"
  >
    <img id="doc-lightbox-img" src="" alt="" class="max-h-full max-w-full rounded-lg shadow-2xl" />
  </div>
</Layout>

<script>
  import Prism from 'prismjs';
  import 'prismjs/components/prism-javascript';
  import 'prismjs/components/prism-typescript';
  import 'prismjs/components/prism-bash';
  import 'prismjs/components/prism-json';

  // Syntax-highlight rendered code blocks. The renderer emits
  // <code class="language-*">; Prism reads textContent (already HTML-escaped) and
  // restyles, so no new injection surface. Runs once for both doc tab panels.
  Prism.highlightAll();

  // Click any rendered doc image to view it fullscreen; click anywhere or press
  // Escape to close. Sources are already scheme-allowlisted by the markdown
  // renderer, so reusing img.src here carries no new injection surface.
  const box = document.getElementById('doc-lightbox');
  const boxImg = document.getElementById('doc-lightbox-img') as HTMLImageElement | null;
  if (box && boxImg) {
    const open = (src: string, alt: string) => {
      boxImg.src = src;
      boxImg.alt = alt;
      box.classList.remove('hidden');
      box.classList.add('flex');
      box.setAttribute('aria-hidden', 'false');
    };
    const close = () => {
      box.classList.add('hidden');
      box.classList.remove('flex');
      box.setAttribute('aria-hidden', 'true');
      boxImg.removeAttribute('src');
    };
    // Only standalone diagrams are zoomable (matches the .doc p > img:only-child
    // CSS) — inline badges stay at natural size and aren't clickable.
    document.querySelectorAll<HTMLImageElement>('.doc p > img:only-child').forEach((img) => {
      img.addEventListener('click', () => open(img.src, img.alt));
    });
    box.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !box.classList.contains('hidden')) close();
    });
  }

  // Doc tabs: switch between the README and Changelog panels. Mirrors the
  // InstallMethods tab pattern — roving tabindex + ArrowLeft/Right, ARIA-correct.
  const tabRoot = document.querySelector('[data-doc-tabs]');
  if (tabRoot) {
    const tabs = Array.from(tabRoot.querySelectorAll<HTMLButtonElement>('[data-doc-tab]'));
    const panels = Array.from(tabRoot.querySelectorAll<HTMLElement>('[data-doc-panel]'));
    const select = (key: string | null) => {
      for (const t of tabs) {
        const on = t.getAttribute('data-doc-tab') === key;
        t.setAttribute('aria-selected', String(on));
        t.tabIndex = on ? 0 : -1;
      }
      for (const p of panels) p.hidden = p.getAttribute('data-doc-panel') !== key;
    };
    tabs.forEach((tab, idx) => {
      tab.addEventListener('click', () => select(tab.getAttribute('data-doc-tab')));
      tab.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
        e.preventDefault();
        const next = tabs[(idx + (e.key === 'ArrowRight' ? 1 : -1) + tabs.length) % tabs.length];
        select(next.getAttribute('data-doc-tab'));
        next.focus();
      });
    });
  }
</script>

<style is:global>
  /* Documentation prose theme for rendered README + CHANGELOG markdown.
     Mirrors the amd-gaia.ai (Mintlify) docs: clear heading hierarchy with a
     ruled h2, comfortable line-height, readable body contrast, chip-style inline
     code, a dark code card, and bordered tables. The markdown renderer emits
     classless semantic tags (website/src/data/markdown.ts) so this stylesheet is
     the single source of truth for how hub markdown looks. */
  .doc { @apply text-[15px] leading-[1.75] text-g-text/90; }
  .doc > :first-child { @apply mt-0; }

  .doc h1 { @apply mt-0 mb-4 text-3xl font-bold tracking-tight text-g-text; }
  .doc h2 { @apply mt-10 mb-4 border-b border-g-border pb-2 text-xl font-semibold tracking-tight text-g-text; }
  .doc h3 { @apply mt-8 mb-3 text-base font-semibold text-g-text; }
  .doc h4 { @apply mt-6 mb-2 text-[15px] font-semibold text-g-text; }

  .doc p { @apply my-4 leading-[1.75] text-g-text/90; }
  .doc strong { @apply font-semibold text-g-text; }
  .doc em { @apply italic; }
  .doc a { @apply font-medium text-g-gold-text underline decoration-g-gold/40 underline-offset-2 transition-colors hover:decoration-g-gold; }

  .doc ul { @apply my-4 list-disc space-y-2 pl-6 marker:text-g-muted; }
  .doc ol { @apply my-4 list-decimal space-y-2 pl-6 marker:text-g-muted; }
  .doc li { @apply leading-[1.7] text-g-text/90; }
  .doc li > ul, .doc li > ol { @apply my-2; }

  .doc code { @apply rounded-md border border-g-border bg-g-surface px-1.5 py-0.5 font-mono text-[0.85em] text-g-text; }
  .doc pre { @apply my-5 overflow-x-auto rounded-xl border border-g-border bg-[#0c0c0e] p-4; }
  .doc pre code { @apply border-0 bg-transparent p-0 font-mono text-[13px] leading-relaxed text-[#e8e8e6]; }

  .doc table { @apply my-6 block w-full overflow-x-auto border-collapse text-left text-[14px]; }
  .doc th { @apply border-b border-g-border bg-g-surface px-3 py-2 text-left font-semibold text-g-text; }
  .doc td { @apply border-b border-g-border px-3 py-2 align-top text-g-text/85; }
  .doc tbody tr:last-child td { @apply border-0; }

  .doc blockquote { @apply my-5 border-l-2 border-g-gold/50 bg-g-surface/40 px-4 py-2 italic text-g-muted; }
  /* Default image: natural size, capped to the column. Keeps inline badges
     (e.g. a shields.io version pill, which sits in a paragraph with other text)
     from being blown up to full width. */
  .doc img { @apply my-5 max-w-full rounded-lg border border-g-border; }
  /* A standalone image — the only child of its paragraph — is a diagram or
     screenshot: fill the column (they read small at natural size) and zoom to
     fullscreen on click (see the lightbox script below). */
  .doc p > img:only-child { @apply w-full cursor-zoom-in transition-colors hover:border-g-gold/50; }
  .doc hr { @apply my-8 border-0 border-t border-g-border; }

  /* Doc tabs (README / Changelog) */
  .doc-tab {
    @apply -mb-px border-b-2 border-transparent px-4 py-2 text-sm font-medium text-g-muted transition-colors hover:text-g-text;
  }
  .doc-tab[aria-selected="true"] {
    @apply border-g-gold text-g-text;
  }

  /* Prism syntax-highlight tokens, tuned for the dark code card (.doc pre). */
  .doc pre .token.comment,
  .doc pre .token.prolog,
  .doc pre .token.doctype,
  .doc pre .token.cdata { color: #6a6a72; font-style: italic; }
  .doc pre .token.punctuation { color: #9aa0aa; }
  .doc pre .token.keyword,
  .doc pre .token.boolean,
  .doc pre .token.atrule { color: #c792ea; }
  .doc pre .token.string,
  .doc pre .token.char,
  .doc pre .token.inserted,
  .doc pre .token.attr-value { color: #c3e88d; }
  .doc pre .token.function,
  .doc pre .token.class-name { color: #82aaff; }
  .doc pre .token.number,
  .doc pre .token.constant,
  .doc pre .token.symbol { color: #f78c6c; }
  .doc pre .token.property,
  .doc pre .token.tag,
  .doc pre .token.attr-name { color: #ffcb6b; }
  .doc pre .token.operator,
  .doc pre .token.entity,
  .doc pre .token.url { color: #89ddff; }
</style>
