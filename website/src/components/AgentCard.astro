import AgentIcon from './AgentIcon.astro';
import {
  categoryLabel,
  languageLabel,
  securityTierLabel,
  securityTierClasses,
  formatBytes,
  type Agent,
} from '../data/catalog';

interface Props {
  agent: Agent;
}

const { agent } = Astro.props;
---

<a
  href={`/hub/${agent.id}`}
  class="agent-card group flex flex-col rounded-xl border border-gaia-border bg-gaia-card/60 p-5 transition-all hover:-translate-y-0.5 hover:border-gaia-accent/40 hover:bg-gaia-card focus-visible:border-gaia-accent/60"
  data-id={agent.id}
  data-name={agent.name.toLowerCase()}
  data-description={agent.description.toLowerCase()}
  data-tags={agent.tags.join(' ').toLowerCase()}
  data-category={agent.category}
  data-language={agent.language}
  data-security-tier={agent.security_tier}
  data-deprecated={String(agent.deprecated)}
>
  <div class="mb-3 flex items-start justify-between gap-3">
    <div class="flex items-center gap-3">
      <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-gaia-accent/10 text-gaia-accent">
        <AgentIcon name={agent.icon} class="w-5 h-5" />
      </span>
      <div>
        <h3 class="font-semibold text-white leading-tight group-hover:text-white">{agent.name}</h3>
        <p class="text-xs text-gaia-muted">{categoryLabel(agent.category)}</p>
      </div>
    </div>
    <span
      class={`flex-shrink-0 rounded-md border px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wide ${securityTierClasses(agent.security_tier)}`}
      title={`Security tier: ${securityTierLabel(agent.security_tier)}`}
    >
      {securityTierLabel(agent.security_tier)}
    </span>
  </div>

  <p class="mb-4 flex-1 text-sm leading-relaxed text-gaia-muted line-clamp-3">{agent.description}</p>

  {agent.deprecated && (
    <p class="mb-3 inline-flex items-center gap-1.5 self-start rounded-md border border-gaia-border bg-gaia-bg/60 px-2 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wide text-gaia-muted">
      Deprecated
    </p>
  )}

  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gaia-muted">
    <span class="font-mono">v{agent.latest_version}</span>
    <span class="text-gaia-border">·</span>
    <span>{languageLabel(agent.language)}</span>
    <span class="text-gaia-border">·</span>
    <span>{formatBytes(agent.download_size_bytes)}</span>
    <span class="text-gaia-border">·</span>
    <span>{agent.author}</span>
  </div>
</a>
