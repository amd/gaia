// Renders an agent's icon by name (lucide-style line icons). Falls back to a
// generic "bot" glyph for unknown names so a new catalog entry never breaks
// the build.

interface Props {
  name: string;
  class?: string;
}

const { name, class: className = 'w-6 h-6' } = Astro.props;

// Inner SVG markup keyed by icon name. Paths are 24x24, stroke-based.
const ICONS: Record<string, string> = {
