{
  "name": "@amd-gaia/agent-ui",
  "version": "0.21.2",
  "type": "module",
  "productName": "GAIA Agent UI",
  "description": "Privacy-first agentic AI interface with document Q&A - runs 100% locally on AMD Ryzen AI",
  "author": "AMD AI Group",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amd/gaia.git",
    "directory": "src/gaia/apps/webui"
  },
  "homepage": "https://amd-gaia.ai/docs/guides/agent-ui",
  "bugs": {
    "url": "https://github.com/amd/gaia/issues"
  },
  "keywords": [
    "gaia",
    "amd",
    "ryzen-ai",
    "agent",
    "ai",
    "local-llm",
    "privacy",
    "rag",
    "document-qa",
    "electron"
  ],
  "main": "main.cjs",
  "bin": {
    "gaia-ui": "bin/gaia-ui.cjs"
  },
  "files": [
    "bin/",
    "dist/",
    "main.cjs",
    "main-safety-net.cjs",
    "preload.cjs",
    "services/",
    "assets/",
    "app.config.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "package": "npm run build && electron-builder --config electron-builder.yml",
    "make": "npm run package",
    "package:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "package:mac": "npm run build && electron-builder --mac --config electron-builder.yml",
    "package:linux": "npm run build && electron-builder --linux --config electron-builder.yml",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.17.0",
    "msw": "^2.7.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "zustand": "^5.0.14"
  }
}
