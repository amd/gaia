# Environment Variables for GAIA Inbox Zero Agent
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ── Email Data ──────────────────────────────────────────────────────────────
# Path to Gmail MBOX takeout file
MBOX_PATH="C:\\Users\\antmi\\Downloads\\takeout-20260420T224647Z-3-001\\Takeout\\Mail\\All mail Including Spam and Trash.mbox"

# ── LLM Provider: Lemonade (OpenAI-compatible) ─────────────────────────────
# Base URL for Lemonade Server (local AMD ROCm inference)
LEMONADE_BASE_URL="http://localhost:8000/api/v1"
# Chat completions endpoint (used by batch classifier)
LEMONADE_URL="http://localhost:8001/v1/chat/completions"

# ── LLM Provider: Anthropic ────────────────────────────────────────────────
# Anthropic Messages API endpoint
ANTHROPIC_URL="https://api.anthropic.com/v1/messages"
# Anthropic API key - NEVER commit this to version control
ANTHROPIC_API_KEY="sk-ant-..."

# ── LLM Gateway (optional, used for judge scoring) ─────────────────────────
LLM_GATEWAY_URL=""
LLM_GATEWAY_KEY=""

# ── Model Selection ────────────────────────────────────────────────────────
# Default model for GAIA agents
GAIA_MODEL="Qwen3.5-35B-A3B-GGUF"
