{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build GAIA Installer",
            "type": "shell",
            "command": "makensis",
            "args": [
                "/DOGA_TOKEN=${input:ogaToken}",
                "${workspaceFolder}/installer/Installer.nsi"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Run JAX (Jira Agent Experience)",
            "type": "shell",
            "windows": {
                "command": "powershell",
                "args": [
                    "-ExecutionPolicy",
                    "Bypass",
                    "-File",
                    "${workspaceFolder}/src/gaia/apps/jira/webui/run.ps1"
                ]
            },
            "linux": {
                "command": "${workspaceFolder}/src/gaia/apps/jira/webui/run.sh"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            },
            "problemMatcher": [],
            "detail": "Build and run the JAX Electron application"
        },
        {
            "label": "Compile GAIA Code Extension",
            "type": "npm",
            "script": "compile",
            "path": "src/vscode/gaia/",
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "focus": false,
                "close": true
            },
            "problemMatcher": "$tsc",
            "detail": "Compile GAIA VSCode extension"
        },
        {
            "label": "C++: CMake Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "${workspaceFolder}/cpp/build",
                "-S", "${workspaceFolder}/cpp",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "detail": "Configure the C++ project (SSL on by default; vcpkg auto-bootstraps OpenSSL on first run)"
        },
        {
            "label": "C++: Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/cpp/build",
                "--config", "Release",
                "--parallel"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile",
            "detail": "Build all C++ targets (Release). Run 'C++: CMake Configure' first if cpp/build does not exist."
        },
        {
            "label": "C++: Test",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir", "${workspaceFolder}/cpp/build",
                "-C", "Release",
                "--output-on-failure"
            ],
            "group": "test",
            "dependsOn": "C++: Build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "detail": "Run C++ unit tests via CTest"
        },
        {
            "label": "Run GAIA docs",
            "type": "shell",
            "command": "npm install && npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/docs"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            },
            "problemMatcher": [],
            "detail": "Install dependencies and run the GAIA documentation development server"
        }
    ],
    "inputs": [
        {
            "id": "ogaToken",
            "type": "promptString",
            "description": "Enter your GitHub token for NPU mode"
        },
        {
            "id": "apiServerUrl",
            "type": "promptString",
            "description": "GAIA API Server URL",
            "default": "http://localhost:8080"
        }
    ]
}